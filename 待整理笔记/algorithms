http://www.lintcode.com/en/problem/single-number/
"^": XOR
0101^1111 = 1010 
```
class Solution {
public:
    int singleNumber(vector<int> &A) {
        if(A.empty()) return 0;
        
        int ret;
        for(vector<int>::const_iterator it = A.begin(); it != A.end(); ++it)
            ret ^= *it;
            
        return ret;
    }
};
